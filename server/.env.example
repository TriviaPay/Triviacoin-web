# --- Required for payment API + Stripe Checkout Session creation ---
STRIPE_SECRET_KEY=sk_test_xxxxx

# --- Required for POST /payments/webhook (signature verification) ---
# Omit only if you are not running the webhook yet (Checkout still works; fulfillment won’t run).
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

PORT=4242

# --- Return URLs for hosted Checkout ---
# Option A (simple): set SPA origin; server builds success/cancel URLs (dev default).
CLIENT_ORIGIN=http://localhost:5173

# Option B (production): set full URLs yourself. Success URL MUST include the literal
# {CHECKOUT_SESSION_ID} so Stripe can substitute the session id.
# STRIPE_SUCCESS_URL=https://app.example.com/success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=https://app.example.com/cancel
