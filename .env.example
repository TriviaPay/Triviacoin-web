# Vite client env (see https://vitejs.dev/guide/env-and-mode.html)
# Main API (app data, auth, etc. — no /api/v1 required in this URL):
# VITE_API_BASE_URL=https://your-app-api.example.com

# Stripe & PayPal are called against: (VITE_PAYMENTS_API_URL || VITE_API_BASE_URL) + /api/v1
# Optional — only if payments are on a different origin (omit /api/v1 here; it is added automatically):
# VITE_PAYMENTS_API_URL=https://your-payments-api.example.com
